<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:id="@+id/main"
    android:background="@color/white"
    android:padding="16dp">


    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Изменения данных"
        android:textStyle="bold"
        android:textSize="24sp"
        android:textColor="@color/black"
        android:layout_marginTop="12dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Имя"
        android:layout_marginBottom="5dp"
        android:textColor="@color/black"
        android:layout_marginTop="12dp"/>

    <EditText
        android:id="@+id/userName"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginBottom="5dp"
        android:textColor="@color/black"
        android:textSize="16sp"
        android:clickable="true"
        android:hint="@string/enter_your_name"
        android:background="@drawable/background_edit_text_profile"
        android:paddingHorizontal="14dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Дата рождения"
        android:layout_marginBottom="5dp"
        android:textColor="@color/black"
        android:layout_marginTop="12dp"/>

    <FrameLayout
        android:id="@+id/frameBirthday"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:contextClickable="false"
        android:focusable="false"
        android:layout_marginBottom="5dp"
        android:clickable="true">

        <EditText
            android:id="@+id/birthday"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:text="ДД/ММ/ГГГГ"
            android:contextClickable="false"
            android:focusable="false"
            android:enabled="false"
            android:textSize="16sp"
            android:paddingStart="15dp"
            android:textColor="@color/black"
            android:background="@drawable/background_edit_text_profile" />

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/dataPiker"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@drawable/icon_calendar"
            android:paddingEnd="10dp"
            android:elevation="5dp"
            android:layout_gravity="center|end"/>
        
        
    </FrameLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Номер телефона"
        android:layout_marginBottom="5dp"
        android:textColor="@color/black"
        android:layout_marginTop="12dp"/>

    <TextView
        android:id="@+id/userPhone"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:enabled="false"
        android:textSize="16sp"
        android:layout_marginBottom="5dp"
        android:textColor="#4A586E"
        android:text="+998974160756"
        android:gravity="center|start"
        android:background="@drawable/background_edit_text_profile"
        android:paddingHorizontal="14dp"/>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/buttonSaveEdit"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:text="Сохранить"
        android:textStyle="bold"
        android:layout_marginTop="16dp"
        android:enabled="true"
        android:background="@drawable/background_button_register"
        android:textColor="@android:color/white"/>

    <TextView
        android:id="@+id/buttonDeleteEdit"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Удалить учетную запись"
        android:textColor="#D32F2F"
        android:layout_gravity="center"
        android:layout_marginTop="12dp"
        android:padding="8dp"/>
</LinearLayout>