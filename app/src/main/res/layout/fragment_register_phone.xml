<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">


    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guidelineHorizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.13"/>

    <androidx.appcompat.widget.AppCompatImageButton
        android:id="@+id/buttonBack"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/icon_back_button"
        android:scaleType="centerCrop"
        android:background="?selectableItemBackground"
        android:padding="7dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="20dp"
        android:layout_marginStart="8dp"/>

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/register_max_way_logo"
        android:layout_width="300dp"
        android:layout_height="100dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/guidelineHorizontal"
        app:layout_constraintBottom_toBottomOf="@id/guidelineHorizontal"
        android:src="@drawable/image_logo"
        />

    <TextView
        android:id="@+id/register_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/register_max_way_logo"
        android:text="@string/login_to_max_way"
        android:textColor="@color/black"
        android:textStyle="bold"
        android:textSize="25sp"/>

    <LinearLayout
        android:id="@+id/panelEditText"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginHorizontal="30dp"
        android:layout_marginTop="50dp"
        android:background="@drawable/background_edit_text_register"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/register_title"
        tools:layout_editor_absoluteX="30dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            android:layout_marginStart="10dp"
            android:gravity="center"
            android:text="+998"
            android:textColor="@color/black"
            android:textSize="18sp"
            android:textStyle="normal" />

        <EditText
            android:id="@+id/editTextRegisterPhone"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@null"
            android:gravity="center|start"
            android:inputType="numberDecimal"
            android:maxLength="9"
            android:paddingStart="3dp"
            android:textColor="@color/black"
            android:textSize="18sp" />


    </LinearLayout>

    <TextView
        android:id="@+id/editTextTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/phone_number"
        android:textColor="@color/black_gray"
        app:layout_constraintBottom_toTopOf="@id/panelEditText"
        app:layout_constraintStart_toStartOf="@id/panelEditText"
        android:layout_marginBottom="5dp"/>

    <TextView
        android:id="@+id/text_oferta"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/press_continue"
        app:layout_constraintTop_toBottomOf="@id/panelEditText"
        app:layout_constraintStart_toStartOf="@id/panelEditText"
        android:layout_marginTop="10dp"
        android:textColor="@color/black_gray"
        android:textSize="12sp"/>

    <TextView
        android:id="@+id/buttonTextPrivacy"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/politics_privacy"
        app:layout_constraintTop_toBottomOf="@id/text_oferta"
        app:layout_constraintStart_toStartOf="@id/text_oferta"
        android:textColor="@android:color/holo_blue_dark"
        android:textSize="12sp"
        android:clickable="true"
        android:focusable="true"/>

    <TextView
        android:id="@+id/textAnd"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/and"
        android:textSize="12sp"
        app:layout_constraintEnd_toStartOf="@id/buttonTextOferta"
        app:layout_constraintStart_toEndOf="@id/buttonTextPrivacy"
        app:layout_constraintBottom_toBottomOf="@id/buttonTextPrivacy"
        android:layout_marginHorizontal="5dp"/>


    <TextView
        android:id="@+id/buttonTextOferta"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/public_offers"
        android:layout_marginStart="5dp"
        android:textColor="@android:color/holo_blue_dark"
        app:layout_constraintBottom_toBottomOf="@id/textAnd"
        app:layout_constraintStart_toEndOf="@id/textAnd"
        android:textSize="12sp"
        android:clickable="true"
        android:focusable="true"/>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/buttonContinue"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginHorizontal="30dp"
        android:layout_marginBottom="60dp"
        android:background="@drawable/background_button_register"
        android:elevation="0dp"
        android:enabled="false"
        android:text="@string/continyu"
        android:textColor="@color/gray"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />


</androidx.constraintlayout.widget.ConstraintLayout>

