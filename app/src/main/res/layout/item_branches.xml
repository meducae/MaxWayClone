<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="20dp"
    android:layout_margin="8dp"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16sp"
        android:background="@color/white">

        <TextView
            android:id="@+id/nameBranch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="max way yangiyo'l"
            android:textColor="@color/black"
            android:textSize="25sp"
            android:textAllCaps="true"
            android:textStyle="bold"
            android:fontFamily="sans-serif-black"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>


        <TextView
            android:id="@+id/addressBranch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintStart_toStartOf="@id/nameBranch"
            app:layout_constraintTop_toBottomOf="@id/nameBranch"
            android:text="Самаркандская улица, 171, Янгиюль\nТашкентская область"
            android:layout_marginTop="20dp"
            android:textStyle="normal"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:textColor="@color/black"/>


        <TextView
            android:id="@+id/textWorkTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="График работы:"
            android:textColor="@color/black"
            app:layout_constraintTop_toBottomOf="@id/addressBranch"
            app:layout_constraintStart_toStartOf="@id/addressBranch"
            app:layout_constraintEnd_toStartOf="@id/textDeliveryTime"
            android:layout_marginTop="20dp"
            android:textSize="14sp"
            android:textAllCaps="false"/>

        <TextView
            android:id="@+id/textDeliveryTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="График работы\nдоставки:"
            android:textColor="@color/black"
            android:gravity="center"
            android:layout_marginStart="15dp"
            app:layout_constraintTop_toTopOf="@id/textWorkTime"
            app:layout_constraintStart_toEndOf="@id/textWorkTime"
            app:layout_constraintEnd_toStartOf="@id/textPhoneBranch"
            android:textSize="14sp"
            android:textAllCaps="false"/>


        <TextView
            android:id="@+id/textPhoneBranch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Телефон:"
            android:textColor="@color/black"
            android:layout_marginStart="15dp"
            app:layout_constraintStart_toEndOf="@id/textDeliveryTime"
            app:layout_constraintTop_toTopOf="@id/textDeliveryTime"
            android:textSize="14sp"
            android:textAllCaps="false"/>

        <TextView
            android:id="@+id/workTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="@id/deliveryTime"
            android:text="09:00-03:00"
            android:layout_marginTop="10dp"
            android:textAllCaps="false"
            android:textSize="14sp"
            android:textColor="@color/black"
            android:textStyle="normal"
            app:layout_constraintStart_toStartOf="@id/textWorkTime"/>
        
        
        <TextView
            android:id="@+id/deliveryTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="09:00-03:00"
            android:layout_marginTop="10dp"
            android:textAllCaps="false"
            android:textSize="14sp"
            android:textColor="@color/black"
            android:textStyle="normal"
            app:layout_constraintStart_toStartOf="@id/textDeliveryTime"
            app:layout_constraintTop_toBottomOf="@id/textDeliveryTime"/>


        <TextView
            android:id="@+id/phoneBranch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+998712005400"
            android:layout_marginTop="10dp"
            android:textAllCaps="false"
            android:textSize="14sp"
            android:textColor="@color/black"
            android:textStyle="normal"
            app:layout_constraintStart_toStartOf="@id/textPhoneBranch"
            app:layout_constraintBottom_toBottomOf="@id/deliveryTime"/>
        
        
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>