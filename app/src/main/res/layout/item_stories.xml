<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="100dp">

    <ImageView
        android:id="@+id/strokeImage"
        android:layout_width="73dp"
        android:layout_height="73dp"
        android:layout_margin="8.5dp"
        android:src="@drawable/stories_bg"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <androidx.cardview.widget.CardView
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:layout_margin="10dp"
        app:cardCornerRadius="250dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <ImageView
            android:id="@+id/imageStories"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:background="@drawable/maxwaylogo" />
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/name"
        android:layout_width="60dp"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif"
        android:text="2+1 Aksiya"
        android:textSize="12dp"
        android:textColor="@color/black"
        android:maxLines="1"
        android:ellipsize="end"
        android:textStyle="normal"
        app:layout_constraintEnd_toEndOf="@+id/strokeImage"
        app:layout_constraintStart_toStartOf="@+id/strokeImage"
        app:layout_constraintTop_toBottomOf="@+id/strokeImage" />




</androidx.constraintlayout.widget.ConstraintLayout>